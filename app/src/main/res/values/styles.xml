<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- نمط الأزرار الأساسي -->
    <style name="HexButton" parent="android:Widget.Button">
        <item name="android:background">@color/accent</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:padding">12dp</item>
        <item name="android:minHeight">48dp</item>
    </style>
    
    <!-- نمط حقل الإدخال -->
    <style name="HexInput" parent="android:Widget.EditText">
        <item name="android:background">@color/surface</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:padding">12dp</item>
    </style>
    
    <!-- نمط النص الطرفي -->
    <style name="TerminalText" parent="android:Widget.TextView">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/accent</item>
    </style>
</resources>
